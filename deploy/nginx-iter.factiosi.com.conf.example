# УСТАРЕЛО: раздельная раздача статики и API на разных портах.
# Текущий прод: один uvicorn на 8010 — см. iter.factiosi.conf.example
#
# Пример для устаревшей схемы (исторически могли класть под другим именем файла)
# Замените пути к fullchain.pem / privkey.pem и root на свои.

server {
    listen 80;
    listen [::]:80;
    server_name iter.factiosi.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name iter.factiosi.com;

    ssl_certificate     /etc/letsencrypt/live/factiosi.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/factiosi.com/privkey.pem;

    # Статика Vite после npm run build
    root /var/www/iter/dist;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Публичная выдача подписки (FastAPI без префикса /api)
    location /config/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location ~ ^/[^/]+/deeplink$ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location /health {
        proxy_pass http://127.0.0.1:8000/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
