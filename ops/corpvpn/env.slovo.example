# CORP VPN — Slovo VPN (пример env для systemd / shell)
# Скопируйте и подставьте свои URL ключей слотов.

CORP_APP_PATH=/path/to/Project Iter/apps/api
CORP_BIND_HOST=127.0.0.1
CORP_PORT=8080

# Slovo preset (как Iter Portal)
CORP_NAME_MODE=slovo
CORP_OUTPUT_FORMAT_MODE=auto
# bypass не используется у Slovo (нет dialerProxy); можно оставить socks
CORP_BYPASS_RENDER_MODE=socks

# Мастер-подписка Slovo (общая или по слотам)
CORP_MASTER_SUBSCRIPTION_URL=https://sub.slovovpn.com/sub/1dc84699b6e342d4a153e3da317fb4d3
# CORP_MASTER_URL_1=https://sub.slovovpn.com/sub/...
# CORP_MASTER_URL_2=https://sub.slovovpn.com/sub/...
# CORP_MASTER_URL_3=https://sub.slovovpn.com/sub/...
# CORP_MASTER_URL_4=https://sub.slovovpn.com/sub/...

CORP_PROFILE_PREFIX=CORP VPN
CORP_CLASH_GROUP_NAME=CORP VPN
CORP_ROUTE_NAME=CORP Route
# Slovo+Happ: глобальный маршрут (1) или routing внутри узлов как у Iter Portal (0)
CORP_HAPP_ROUTING_DEEPLINK=1
# CORP_ROUTE_DIRECT_SITES=domain:.ru
# geosite:category-ru
# CORP_SLOVO_RU_DIRECT_ROUTES=domain:2ip.ru

CORP_CACHE_TTL=300
# CORP_SLOT_STATE_FILE=/var/lib/corpvpn/slot-state.json
