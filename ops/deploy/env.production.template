# === Iter.Factiosi — продакшен ===
#
# Docker Compose: скопируйте в корень репозитория:
#   cp ops/deploy/env.production.template .env && chmod 600 .env
#
# Заполните пустые значения. Не коммитьте .env.

# --- Compose (подстановка в docker-compose.yml) ---
# Внешний порт HTTP контейнера web (за reverse-proxy или напрямую)
ITER_HTTP_PORT=8080

# --- Приложение API (передаются в контейнер api) ---
SECRET_KEY=
OTP_PEPPER=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

ADMIN_EMAIL=

# В контейнере переопределяется compose; оставьте так для SQLite на volume
DATABASE_URL=sqlite:////app/data/iter.db

# В Docker статику отдаёт контейнер web; API не раздаёт SPA.
STATIC_DIST_DIR=

FRONTEND_ORIGINS=https://iter.factiosi.com
PUBLIC_PORTAL_URL=https://iter.factiosi.com


# --- Почта Mail.ru (465, implicit TLS) ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=noreply@factiosi.com
SMTP_PASSWORD=
SMTP_FROM=noreply@factiosi.com
SMTP_FROM_DISPLAY_AUTH=Authorization Iter.Factiosi
SMTP_FROM_DISPLAY_NOTIFICATION=Notification Iter.Factiosi

# В продакшене обязательно false
DEV_RELAXED_AUTH=false

# Опционально: email через запятую для первичного заполнения whitelist при пустой БД
INITIAL_WHITELIST_EMAILS=

# --- На сервере после сохранения .env в корне репозитория ---
# docker compose build
# docker compose up -d
# curl -sS http://127.0.0.1:${ITER_HTTP_PORT:-8080}/health
# За хостовым nginx с TLS проксируйте на 127.0.0.1:ITER_HTTP_PORT — см. ops/deploy/iter.factiosi.conf.example
