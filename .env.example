# Скопируйте в .env на сервере и заполните. Не добавляйте .env в git.
# Docker Compose: этот файл в корне репозитория.
# Локальный API: переменные в apps/api/.env — шаблон apps/api/.env.example
# Полный комментированный шаблон compose: ops/deploy/env.production.template

# Порт публикации стека compose (см. docker-compose.yml)
ITER_HTTP_PORT=8080

SECRET_KEY=
OTP_PEPPER=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

ADMIN_EMAIL=

DATABASE_URL=sqlite:////app/data/iter.db

# Запятая без пробелов для нескольких origin
FRONTEND_ORIGINS=https://iter.factiosi.com
PUBLIC_PORTAL_URL=https://iter.factiosi.com

# Почта Mail.ru (прод): 465 + SSL
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=noreply@factiosi.com
SMTP_PASSWORD=
SMTP_FROM=noreply@factiosi.com
# Имя в почтовом клиенте (адрес один — см. SMTP_FROM)
SMTP_FROM_DISPLAY_AUTH=Authorization Iter.Factiosi
SMTP_FROM_DISPLAY_NOTIFICATION=Notification Iter.Factiosi

DEV_RELAXED_AUTH=false

# Опционально: начальный whitelist через запятую
INITIAL_WHITELIST_EMAILS=
